# Doffins CleanCare - Comprehensive GitIgnore

# Dependencies
node_modules/
.pnpm-store/
jspm_packages/

# Production / Build
dist/
dist-ssr/
build/
*.local

# Environment Variables & Secrets
#.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database (Keep schema, ignore actual binary data)
#*.db
*.db-journal
#*.sqlite
*.sqlite-journal
#!seed.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS Specific
.DS_Store
Thumbs.db
desktop.ini

# IDE Settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
coverage/
test-results/

# Vite / Misc
.vite
docs/.vitepress/dist
